# ── Server ───────────────────────────────────────────────────────────────────
# Bind address — 0.0.0.0 listens on all interfaces (required for LAN access)
# HOST=0.0.0.0

# API server port — change if running multiple instances (e.g. PORT=3002)
# PORT=3001

# ── Seats.aero Partner API ────────────────────────────────────────────────────
# Powers the Award Search tab — live award availability across 30+ programs.
# Sign up at: https://seats.aero (paid partner API, $9.99/month)
SEATS_API_KEY=

# ── Sky Scrapper (Skyscanner) via RapidAPI ────────────────────────────────────
# Powers live business/premium economy cash price lookups.
# Free tier: 100 calls/month — sufficient for personal use.
# Sign up at: https://rapidapi.com → search "sky-scrapper" → subscribe (free tier)
RAPIDAPI_KEY=

# ── Travelpayouts ─────────────────────────────────────────────────────────────
# Powers economy cash price baseline lookups.
# Free API — sign up at: https://www.travelpayouts.com/developers/api
TRAVELPAYOUTS_TOKEN=

# ── Award Alerts ──────────────────────────────────────────────────────────────
# How often to poll seats.aero for alert matches (milliseconds). Default: 900000 (15 min)
# ALERT_POLL_INTERVAL_MS=900000

# Maximum number of active alerts. Default: 10
# MAX_ALERTS=10

# ── Pushover (push notifications) ────────────────────────────────────────────
# When set, Sarif sends a push notification to your device for each new alert match.
# If omitted, push notifications are disabled — alert evaluation is unaffected.
# Get your API token at: https://pushover.net/apps/build
# PUSHOVER_TOKEN=
# PUSHOVER_USER_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite database path (default: server/data/sarif.db)
# For Docker: mount a volume and set e.g. SARIF_DB_PATH=/data/sarif.db
# SARIF_DB_PATH=/data/sarif.db
